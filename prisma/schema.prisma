generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  String?
  email String? @unique
  image String?

  events Event[]
}

model Event {
  id     String   @id @default(auto()) @map("_id") @db.ObjectId
  title  String
  date   DateTime
  userId String   @db.ObjectId
  user   User     @relation(fields: [userId], references: [id])
}